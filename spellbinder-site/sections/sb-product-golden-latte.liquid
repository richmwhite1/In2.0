{{- 'section-main-product.css' | asset_url | stylesheet_tag -}}
{{- 'component-price.css' | asset_url | stylesheet_tag -}}
{{- 'component-slider.css' | asset_url | stylesheet_tag -}}
{{- 'component-deferred-media.css' | asset_url | stylesheet_tag -}}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' -%}
{%- assign product_form_id = 'product-form-golden-latte-' | append: section.id -%}

{%- comment -%}
  ══════════════════════════════════════════════
  SECTION 1 — PRODUCT HERO
  ══════════════════════════════════════════════
{%- endcomment -%}

<product-info
  id="MainProduct-{{ section.id }}"
  class="sbp-hero-wrapper"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  <div class="sbp-hero">

    {%- comment -%} LEFT — Gallery {%- endcomment -%}
    <div class="sbp-hero__gallery">
      {%- if product.media.size > 0 -%}
        <div class="sbp-gallery">
          {%- for media in product.media -%}
            <div class="sbp-gallery__slide {% if forloop.first %}sbp-gallery__slide--active{% endif %}">
              {%- if media.media_type == 'image' -%}
                {{
                  media
                  | image_url: width: 1200
                  | image_tag:
                    loading: forloop.first | default: 'lazy',
                    fetchpriority: forloop.first | default: 'auto',
                    widths: '600, 900, 1200',
                    class: 'sbp-gallery__img',
                    alt: media.alt
                }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="sbp-gallery__thumbs">
            {%- for media in product.media limit: 6 -%}
              {%- if media.media_type == 'image' -%}
                <button class="sbp-gallery__thumb {% if forloop.first %}sbp-gallery__thumb--active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  aria-label="{{ media.alt | default: product.title | escape }} image {{ forloop.index }}">
                  {{
                    media
                    | image_url: width: 120
                    | image_tag:
                      loading: 'lazy',
                      widths: '80, 120',
                      class: 'sbp-gallery__thumb-img',
                      alt: media.alt
                  }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="sbp-gallery sbp-gallery--placeholder">
          <div class="sbp-gallery__slide sbp-gallery__slide--active">
            {{ 'product-2' | placeholder_svg_tag: 'sbp-placeholder-svg' }}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT — Product Info {%- endcomment -%}
    <div class="sbp-hero__info">

      <div class="sbp-hero__flag sbp-hero__flag--pink">★ Best Seller</div>

      <p class="sbp-hero__tagline">Your daily recovery ritual. Powered by medicinal mushrooms, concentrated botanicals, and ancient spice wisdom.</p>

      <h1 class="sbp-hero__name">{{ product.title | default: 'Golden Latte' }}</h1>

      <div class="sbp-hero__price" id="price-{{ section.id }}" role="status">
        {%- render 'price', product: product, use_variant: true, show_badges: true, price_class: 'price--large' -%}
        <p class="sbp-hero__per">/ 30-day supply · 30 servings</p>
      </div>

      {%- comment -%} Add to cart form {%- endcomment -%}
      {%- form 'product', product,
        id: product_form_id,
        class: 'sbp-product-form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          class="product-variant-id"
          form="{{ product_form_id }}"
        >

        <div class="sbp-product-form__error" role="alert" aria-live="polite" hidden>
          <span class="sbp-product-form__error-message"></span>
        </div>

        <button
          type="submit"
          name="add"
          class="sb-btn sb-btn--filled sbp-add-to-cart"
          {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
        >
          {%- if product.selected_or_first_available_variant.available -%}
            Add to Cart — Begin Your Ritual
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- comment -%} Benefit bullets {%- endcomment -%}
      <ul class="sbp-hero__bullets">
        <li>Supports your body's natural inflammatory response after daily wear and stress</li>
        <li>Eight medicinal mushrooms provide broad-spectrum immune and adaptogenic support</li>
        <li>Turmeric and ginger juice extracts — concentrated for maximum potency</li>
        <li>Sprouted broccoli and alfalfa sprouts supply sulforaphane to support natural detox pathways</li>
        <li>Black pepper extract enhances curcumin bioavailability up to 2000%</li>
        <li>Warming, deeply comforting — perfect as a morning alternative or evening wind-down</li>
      </ul>

      <p class="sbp-hero__trust">★★★★★ · 500+ ritual converts · No artificial anything</p>

    </div>
  </div>

  {%- render 'product-media-modal', variant_images: variant_images -%}

  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
</product-info>

{%- comment -%}
  Simple gallery JS — thumbnail click switches main image
{%- endcomment -%}
<script>
  (function() {
    var gallery = document.querySelector('.sbp-gallery');
    var thumbs = document.querySelectorAll('.sbp-gallery__thumb');
    if (!gallery || !thumbs.length) return;
    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        var idx = parseInt(this.dataset.index, 10);
        var slides = gallery.querySelectorAll('.sbp-gallery__slide');
        slides.forEach(function(s) { s.classList.remove('sbp-gallery__slide--active'); });
        thumbs.forEach(function(t) { t.classList.remove('sbp-gallery__thumb--active'); });
        if (slides[idx]) slides[idx].classList.add('sbp-gallery__slide--active');
        this.classList.add('sbp-gallery__thumb--active');
      });
    });
  })();
</script>

{%- comment -%}
  ══════════════════════════════════════════════
  SECTION 2 — FORMULA STORY
  ══════════════════════════════════════════════
{%- endcomment -%}

<section class="sbp-section sbp-section--deep sbp-formula" id="SbpFormula">
  <div class="sbp-container sbp-formula__inner">
    <div class="sbp-formula__label">
      <span class="sb-eyebrow">The Formula</span>
    </div>
    <div class="sbp-formula__content">
      <h2 class="sbp-section-headline">The most intentional turmeric latte ever formulated.</h2>
      <div class="sbp-formula__body">
        <p>Most turmeric lattes are turmeric, milk, and maybe a sprinkle of cinnamon. Ours contains an 8-mushroom blend, concentrated turmeric and ginger juice extracts — not powders, extracts — sulforaphane-rich sprouted greens, and black pepper to unlock curcumin's full potential in your body.</p>
        <p>This is what recovery feels like when it is built into your daily ritual. The Golden Latte is the perfect companion to Wizard's Brew — and it can also stand completely alone as the most nourishing warm drink you have ever made.</p>
      </div>
    </div>
  </div>
</section>

{%- comment -%}
