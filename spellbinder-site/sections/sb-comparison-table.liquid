<section class="sb-section sb-section--base sb-comparison" id="SbComparison">
  <details class="sb-mobile-collapse">
    <summary class="sb-mobile-collapse__toggle">
      The Honest Comparison <span class="sb-mobile-collapse__icon" aria-hidden="true"></span>
    </summary>
    <div class="sb-container">

    <div class="sb-comparison__header">
      <span class="sb-eyebrow">The Honest Comparison</span>
      <h2 class="sb-section-headline">Not all morning drinks are equal.</h2>
    </div>

    <div class="sb-comparison__table-wrap">
      <table class="sb-comparison-table" role="table">
        <thead>
          <tr>
            <th class="sb-comparison-table__col-head" scope="col">Your Morning Drink</th>
            <th class="sb-comparison-table__col-head" scope="col">What You Get</th>
            <th class="sb-comparison-table__col-head" scope="col">The Cost</th>
            <th class="sb-comparison-table__col-head" scope="col">Long-Term Effect</th>
          </tr>
        </thead>
        <tbody>
          <tr class="sb-comparison-table__row">
            <td class="sb-comparison-table__drink">Coffee <span class="sb-comparison-table__note">(2–3 cups)</span></td>
            <td>Fast energy, then jitters and crash</td>
            <td>Cortisol spike, blood sugar swing</td>
            <td>Adrenal stress over time</td>
          </tr>
          <tr class="sb-comparison-table__row">
            <td class="sb-comparison-table__drink">Energy Drinks</td>
            <td>Quick stimulation</td>
            <td>Artificial ingredients, inflammation</td>
            <td>Metabolic disruption</td>
          </tr>
          <tr class="sb-comparison-table__row">
            <td class="sb-comparison-table__drink">Standard Wellness Tea</td>
            <td>Mild comfort, vague benefits</td>
            <td>Under-dosed, often sweetened</td>
            <td>Little meaningful change</td>
          </tr>
          <tr class="sb-comparison-table__row sb-comparison-table__row--highlight">
            <td class="sb-comparison-table__drink">
              Spellbinder <span class="sb-comparison-table__bolt">⚡</span>
            </td>
            <td>Sustained energy, cellular nourishment, systemic support</td>
            <td>Zero junk — clean, intentional ingredients</td>
            <td>Daily Biological Intelligence compounding over months</td>
          </tr>
        </tbody>
      </table>
    </div>

    </div>
  </details>
</section>

{% schema %}
{
  "name": "SB — Comparison Table",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "SB — Comparison Table"
    }
  ]
}
{% endschema %}
