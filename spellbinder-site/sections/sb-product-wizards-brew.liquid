          <span class="sbp-accordion__label">Adaptogens</span>
          <span class="sbp-accordion__caret"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
