<section class="sb-section sb-section--deep sb-hiw" id="SbHowItWorks">
  <details class="sb-mobile-collapse">
    <summary class="sb-mobile-collapse__toggle">
      How It Works <span class="sb-mobile-collapse__icon" aria-hidden="true"></span>
    </summary>
    <div class="sb-container">

    <div class="sb-hiw__header">
      <span class="sb-eyebrow">The Process</span>
      <h2 class="sb-section-headline">How It Works</h2>
    </div>

    <div class="sb-hiw__grid">

      <div class="sb-hiw-step">
        <div class="sb-hiw-step__number">01</div>
        <div class="sb-hiw-step__connector" aria-hidden="true"></div>
        <h3 class="sb-hiw-step__title">Choose Your Elixir</h3>
        <p class="sb-hiw-step__body">Start with the Longevity Tea, the Turmeric Latte, or both. Most devotees begin with one and add the second within a week.</p>
      </div>

      <div class="sb-hiw-step">
        <div class="sb-hiw-step__number">02</div>
        <div class="sb-hiw-step__connector" aria-hidden="true"></div>
        <h3 class="sb-hiw-step__title">Prepare Your Brew</h3>
        <p class="sb-hiw-step__body">Add one scoop to 8–12 oz of hot water. Stir or froth. Add a splash of your favorite milk. No boiling required.</p>
      </div>

      <div class="sb-hiw-step">
        <div class="sb-hiw-step__number">03</div>
        <div class="sb-hiw-step__connector" aria-hidden="true"></div>
        <h3 class="sb-hiw-step__title">Drink Slowly</h3>
        <p class="sb-hiw-step__body">Give yourself five minutes. Breathe. Let the aroma reach you before the first sip. This is the ritual part — and it matters.</p>
      </div>

      <div class="sb-hiw-step">
        <div class="sb-hiw-step__number">04</div>
        <h3 class="sb-hiw-step__title">Trust the Compound Effect</h3>
        <p class="sb-hiw-step__body">Biological Intelligence doesn't work in a day — it works over time, every day. Most notice something meaningful within week one.</p>
      </div>

    </div>
    </div>
  </details>
</section>

